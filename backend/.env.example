# ---- Core ----
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ---- Postgres (Prisma) ----
# Local dev: run `npx prisma dev` (Prisma Postgres) or point at any Postgres URL.
DATABASE_URL="postgresql://user:password@localhost:5432/design_power?schema=public"

# ---- Redis (cache + BullMQ queues) ----
REDIS_URL=redis://localhost:6379

# ---- Phase 2: Google OAuth + sessions ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback
# Session JWT signing secret (>=16 chars; REQUIRED in production).
JWT_SECRET=
# Comma-separated emails auto-allowed AND promoted to ADMIN on first login
# (bootstraps the first admin). e.g. you@gmail.com,teammate@gmail.com
BOOTSTRAP_ADMIN_EMAILS=

# ---- Phase 4: generation providers + storage ----
# fal.ai (Person) — synchronous fal.run, no webhook needed
FAL_KEY=
# nano-gpt (Item images + Person prompt builder)
NANO_GPT_API_KEY=
# Cloudinary (result + reference storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
