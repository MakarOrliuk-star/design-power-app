// Prisma schema for the Design Power image generator (rewrite).
// Approved in Phase 0. v1 scope: Person (fal.ai) + Item (nano-gpt), Google OAuth
// + email allowlist with an admin-managed UI. Edit/Background/Smartico/Figma are
// out of v1 (reserved enum values are added when those land).
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  runtime      = "nodejs"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Auth & Allowlist
// ============================================================

enum Role {
  ADMIN
  DESIGNER
  CRM
  // MANAGER reaches BOTH the Design and CRM zones (but not /admin). Treated like
  // ADMIN by requireZone for zone access; blocked from admin routes by requireAdmin.
  MANAGER
  // Super-designer (TASK super-designer): DESIGNER zone access + own-brand
  // management via /api/my-brands (create/edit/delete/test only brands they
  // created). No CRM, no /admin.
  SUPER_DESIGNER
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String?
  avatarUrl   String?
  googleId    String?   @unique
  role        Role      @default(DESIGNER)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  lastLoginAt DateTime?

  generations         Generation[]
  batches             Batch[]
  favorites           BrandFavorite[]
  itemFavorites       ItemStyleFavorite[]
  crmFavorites        CrmServiceFavorite[]
  tournamentOverrides UserTournamentPromptOverride[]
  brandsCreated       Brand[]

  @@index([email])
}

/// Allowlist: login is permitted only for emails present here (or an active User).
model AllowedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  note      String?
  addedBy   String? // email of the admin who added it
  createdAt DateTime @default(now())
}

// ============================================================
// Catalog
// ============================================================

model Brand {
  id                String   @id @default(cuid())
  name              String   @unique // e.g. "Spinogambino(Men)"
  smarticoName      String? // canonical Smartico name (unused in v1)
  isActive          Boolean  @default(true)
  // Forced output format (TASK §7): "9:16" → every generation of this brand is
  // 9:16 regardless of the user's 1:1/9:16 pick; null → honour the pick.
  // Edits follow automatically — the edit flow probes the source image pixels.
  forcedAspectRatio String?
  // fal.ai model override (admin-managed). null → default fal-ai/nano-banana-2;
  // otherwise a MODEL_REGISTRY key (e.g. "xai/grok-imagine-image"). The endpoint
  // (/edit vs text-to-image) and request body are derived from the registry.
  imageModel        String?
  // Ownership (TASK super-designer): the user who created the brand. Legacy
  // brands are null ("nobody's") — editable only via the admin panel. A
  // super-designer may edit/delete/test ONLY brands where createdById = self.
  createdById       String?
  createdBy         User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt         DateTime @default(now())

  categories      BrandCategoryLink[]
  nanoRef         BrandNanoRef?
  prompts         PromptTemplate[]
  favorites       BrandFavorite[]
  testGenerations Generation[]

  @@index([createdById])
}

/// Brand tabs in the picker: Favorites / All Aramuz / Korea / Sport / ...
model BrandCategory {
  id     String              @id @default(cuid())
  name   String              @unique
  order  Int                 @default(0)
  brands BrandCategoryLink[]
}

model BrandCategoryLink {
  brandId    String
  categoryId String
  brand      Brand         @relation(fields: [brandId], references: [id], onDelete: Cascade)
  category   BrandCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([brandId, categoryId])
}

model BrandFavorite {
  userId  String
  brandId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand   Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@id([userId, brandId])
}

/// Per-user favorite Item styles. Item styles are identified by their string key
/// (the ITEM PromptTemplate key), not a Brand id — so this is keyed by styleKey
/// rather than an FK. Mirrors BrandFavorite for the Person side.
model ItemStyleFavorite {
  userId   String
  styleKey String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, styleKey])
}

/// Per-user favorite CRM services. Services are a static front-end list (not DB
/// rows), so this is keyed by a string serviceKey rather than an FK — mirrors
/// ItemStyleFavorite. Valid keys are enforced in the route, not the schema.
model CrmServiceFavorite {
  userId     String
  serviceKey String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, serviceKey])
}

model Theme {
  id    String @id @default(cuid())
  name  String @unique
  order Int    @default(0)
}

/// Pre-baked references + style prompt per brand (legacy "NanoRefs" tab).
model BrandNanoRef {
  id               String   @id @default(cuid())
  brandId          String   @unique
  brand            Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  referenceImages  String[] // 1..3 Cloudinary URLs
  stylePrompt      String
  cloudinaryFolder String?
  updatedAt        DateTime @updatedAt
}

enum PromptType {
  PERSON
  ITEM
  // Tournaments page (TASK feature/tournament-page): the system wrapper that
  // every tournament element prompt is injected into via {{prompt}}. Single
  // row: key="system". Editable by ADMIN/MANAGER via the tournament admin.
  TOURNAMENT
}

/// System prompts (legacy "Prompts" tab).
/// PERSON -> system content for the nano-gpt chat prompt builder.
/// ITEM   -> wrapper template; {{prompt}} marks where user text is injected.
model PromptTemplate {
  id        String     @id @default(cuid())
  type      PromptType
  key       String // brand name (PERSON) or style name (ITEM)
  brandId   String?
  brand     Brand?     @relation(fields: [brandId], references: [id])
  content   String
  updatedAt DateTime   @updatedAt

  @@unique([type, key])
}

// ============================================================
// Generation
// ============================================================

enum RefMode {
  ALL
  EACH
}

enum BatchStatus {
  IN_PROGRESS
  COMPLETED
  PARTIAL_FAILURE
  FAILED
  CANCELLED
}

enum ActionType {
  FULL // Person full generation
  CREATE_ITEM // Create Items (nano-gpt)
  NANO_REF // Brand-locked Person generation
  TOURNAMENT // Tournaments page batch (one batch per category)
}

enum GenerationStatus {
  QUEUED
  PROCESSING
  DONE
  FAILED
  CANCELLED
  READY_FOR_RETRY
}

enum JobProvider {
  FAL
  NANO_GPT
}

enum JobStatus {
  QUEUED
  PROCESSING
  DONE
  FAILED
  CANCELLED
}

model Batch {
  id            String      @id @default(cuid())
  legacyBatchId String?     @unique // e.g. "PERSON_20260601_120000_ABC123"
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  actionType    ActionType
  theme         String?
  description   String?
  status        BatchStatus @default(IN_PROGRESS)
  refMode       RefMode? // Person only
  createdAt     DateTime    @default(now())

  generations Generation[]
  jobs        Job[]

  @@index([userId, createdAt])
}

/// One row = one generated image (legacy RefSheet row).
model Generation {
  id                String           @id @default(cuid())
  batchId           String?
  batch             Batch?           @relation(fields: [batchId], references: [id])
  userId            String
  user              User             @relation(fields: [userId], references: [id])
  brandName         String // denormalized, matches the legacy sheet
  theme             String?
  description       String? // prompt / [NANO_REF] etc.
  referenceImages   String[]
  generatedImageUrl String?
  status            GenerationStatus @default(QUEUED)
  statusMessage     String? // human-readable status text
  actionType        ActionType
  isEdit            Boolean          @default(false)
  // Brand test run (TASK super-designer, actionType=NANO_REF): created from the
  // "Протестировать бренд" panel. isTest=true keeps it OUT of Results/Archive
  // until the user hits «Сохранить» (flips to false). brandId survives brand
  // renames so Library keeps showing saved tests; SetNull on brand deletion.
  isTest            Boolean          @default(false)
  brandId           String?
  brand             Brand?           @relation(fields: [brandId], references: [id], onDelete: SetNull)
  // Tournaments page (actionType=TOURNAMENT only, null elsewhere). The final
  // prompt is pre-built at batch creation and stored in `description`; the file
  // name is fixed here too so the ZIP/Result tab never re-derive it.
  tourCategoryKey   String? // "tournament" | "lotterie" | "provider" | "calendar_vip"
  tourElementName   String? // e.g. "Tournament_1", "Playson & Booongo"
  tourMode          TournamentMode?
  tourFileName      String? // e.g. "Bonuskong_Tournament_1_2" (no extension)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  job Job?

  @@index([userId, createdAt])
  @@index([brandName])
  @@index([status])
}

/// Async job ledger (legacy "_jobs" tab); bridges Generation rows to fal/nano-gpt.
/// Synced with the BullMQ queue at runtime.
model Job {
  id                String      @id @default(cuid())
  provider          JobProvider
  type              PromptType // PERSON | ITEM
  providerRequestId String?     @unique // fal request_id
  generationId      String      @unique
  generation        Generation  @relation(fields: [generationId], references: [id], onDelete: Cascade)
  batchId           String?
  batch             Batch?      @relation(fields: [batchId], references: [id])
  status            JobStatus   @default(QUEUED)
  statusUrl         String?
  cancelUrl         String?
  responseUrl       String?
  cloudinaryFolder  String?
  attempts          Int         @default(0)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([status, type])
}

// ============================================================
// Smartico (Unique-Image-Smartico CRM service)
// ============================================================

/// Canonical Smartico brand_id values. Used to normalize ZIP folder names when
/// generating the Smartico function: a folder "baxterbet" / "Baxter Bet" maps to
/// the canonical "Baxterbet". Admin-managed (CRM service maintenance); seeded
/// from the legacy hardcoded SMARTICO_BRANDS list.
model SmarticoBrand {
  id        String   @id @default(cuid())
  name      String   @unique // canonical brand_id, e.g. "BrunoCasino"
  createdAt DateTime @default(now())
}

/// Dedup cache for Smartico image uploads (TASK D3). Keyed by ZIP name + brand +
/// type + locale; stores the content MD5 so re-uploading the same archive reuses
/// the existing Cloudinary asset instead of re-uploading. A changed MD5 overwrites
/// the asset under the same publicId.
model SmarticoAsset {
  id        String   @id @default(cuid())
  zipName   String // Cloudinary folder = the uploaded ZIP file name (no .zip)
  brand     String // raw brand folder name from the ZIP
  type      String // email | push | pop-up_1 | pop-up_2
  locale    String   @default("default") // default | KO
  md5       String // MD5 of the image bytes
  secureUrl String
  publicId  String
  updatedAt DateTime @updatedAt

  @@unique([zipName, brand, type, locale])
}

/// Marketing-text scan cache + whitelist for CRM email images (TASK Трек A).
/// Keyed by the image bytes' MD5: the same bytes are never scanned twice, and
/// "пометить ок" (approvedOk) suppresses the warning for everyone until the
/// bytes — and therefore the MD5 — change.
model ImageTextScan {
  md5        String   @id
  hasText    Boolean // VLM verdict: baked-in marketing text present
  text       String   @default("") // the promo text the model could read
  confidence Float    @default(0) // model's self-reported 0..1 (debug only)
  approvedOk Boolean  @default(false) // manager marked this image as OK
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ============================================================
// Tournaments page (TASK feature/tournament-page)
// ============================================================

enum TournamentMode {
  BASE
  VIP
}

/// Generation categories (the 4 base ones are seeded; admin can create more,
/// rename and delete). `key` doubles as the ZIP folder name and is frozen at
/// creation; deletion is HARD (cascades to elements/prompts/overrides) —
/// Generation history keeps denormalized names, so old ZIP exports survive.
model TournamentCategory {
  id        String          @id @default(cuid())
  key       String          @unique // "tournament" | "lotterie" | "provider" | "calendar_vip"
  name      String // column title, e.g. "Tournament (Bs)"
  // true (tournament/lotterie): the column has a Base/VIP toggle, each element
  // keeps TWO prompts. false: single prompt in `fixedMode`.
  hasModes  Boolean         @default(false)
  fixedMode TournamentMode? // provider -> BASE, calendar_vip -> VIP; null when hasModes
  order     Int             @default(0)

  elements TournamentElement[]
}

/// Elements inside a category (Tournament_1, Lottery_2, providers...). Admin
/// adds/removes; removal is soft (isActive=false) — Generation history keeps
/// the denormalized element name.
model TournamentElement {
  id              String             @id @default(cuid())
  categoryId      String
  category        TournamentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name            String // "Tournament_1", "Playson & Booongo"
  order           Int                @default(0)
  isActive        Boolean            @default(true)
  // Provider category only: the 2 provider reference images (Cloudinary URLs)
  // baked into every generation of this element. Empty for other categories.
  referenceImages String[]
  createdAt       DateTime           @default(now())

  prompts   TournamentPrompt[]
  overrides UserTournamentPromptOverride[]

  @@unique([categoryId, name])
}

/// Global default prompts, visible to every designer. tournament/lotterie
/// elements have a BASE and a VIP row; provider -> BASE only; calendar_vip ->
/// VIP only. `updatedAt` drives the "default changed" banner on overrides.
model TournamentPrompt {
  id        String            @id @default(cuid())
  elementId String
  element   TournamentElement @relation(fields: [elementId], references: [id], onDelete: Cascade)
  mode      TournamentMode
  content   String
  updatedAt DateTime          @updatedAt

  @@unique([elementId, mode])
}

/// Per-user local prompt edits (Phase 0 decision: DB, not localStorage; live
/// until reset). baseUpdatedAt snapshots the default's updatedAt at edit/ack
/// time: default.updatedAt > baseUpdatedAt -> the UI shows "default changed:
/// keep mine / take new default".
model UserTournamentPromptOverride {
  userId        String
  elementId     String
  mode          TournamentMode
  content       String
  baseUpdatedAt DateTime
  updatedAt     DateTime       @updatedAt

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  element TournamentElement @relation(fields: [elementId], references: [id], onDelete: Cascade)

  @@id([userId, elementId, mode])
}

/// Single-row global DES counter (seeded id=1, value=100000). Incremented
/// atomically (UPDATE ... RETURNING) BEFORE each ZIP download, so the first
/// issued archive is DES-100001 (per the spec's own example).
model DesCounter {
  id    Int @id @default(1)
  value Int
}

/// One row per issued ZIP download (a new DES number on EVERY download).
model ZipExport {
  id        String   @id @default(cuid())
  desNumber Int      @unique
  userId    String
  batchId   String? // set for whole-batch exports
  imageIds  String[] // Generation ids that went into the archive
  createdAt DateTime @default(now())
}
